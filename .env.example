# Binance — crea esta API key con SOLO el permiso "Enable Reading" activado.
# Deja "Enable Spot & Margin Trading" y "Enable Withdrawals" DESACTIVADOS.
# Con eso, esta key físicamente no puede colocar órdenes ni mover fondos.
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Cuenta de Gmail desde la que te llegan los avisos.
# Usa una contraseña de aplicación, no tu contraseña normal:
# https://myaccount.google.com/apppasswords
GMAIL_USER=
GMAIL_APP_PASSWORD=
NOTIFY_TO=tu-correo@gmail.com

# Cada cuántos minutos revisa precios y reglas
CHECK_INTERVAL_MINUTES=5
