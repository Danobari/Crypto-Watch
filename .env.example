# Binance — crea esta API key con SOLO el permiso "Enable Reading" activado.
# Deja "Enable Spot & Margin Trading" y "Enable Withdrawals" DESACTIVADOS.
# Con eso, esta key físicamente no puede colocar órdenes ni mover fondos.
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Cuenta de Gmail desde la que te llegan los avisos.
# Usa una contraseña de aplicación, no tu contraseña normal:
# https://myaccount.google.com/apppasswords
GMAIL_USER=
GMAIL_APP_PASSWORD=
NOTIFY_TO=tu-correo@gmail.com

# Cada cuántos minutos revisa precios y reglas
CHECK_INTERVAL_MINUTES=5

# Cuándo sincroniza Tracker.xlsx (formato cron). Por defecto, una vez al
# día a las 8am. Ciérralo en Excel antes de esa hora si lo tienes abierto,
# o la sincronización de ese ciclo fallará (sin problema, lo reintenta en
# el siguiente).
EXCEL_SYNC_CRON=0 8 * * *

# Supabase — reemplaza a los archivos data/*.json como almacenamiento.
# Project URL y la "service_role secret" key están en tu proyecto de
# Supabase → Settings → API. La service_role key NUNCA debe exponerse al
# frontend ni subirse a git — solo la usa este servidor.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
